generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  ACCOUNTANT
}

// ─── Tenant ──────────────────────────────────────────────────────────────────

model Tenant {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  nif            String   @unique
  vertical       String   @default("generic") // limpieza | construccion | medicos | servicios_pro | retail | generic
  plan           String   @default("free")    // free | starter | pro | enterprise
  sectorMetadata Json?    @map("sector_metadata")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users              User[]
  clients            Client[]
  products           Product[]
  invoices           Invoice[]
  recurringContracts RecurringContract[]
  invitations        Invitation[]

  @@map("tenants")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @db.Uuid // matches Supabase auth.users.id
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  name      String?
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
}

// ─── Client ───────────────────────────────────────────────────────────────────

model Client {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  nif            String
  address        String?
  email          String?
  phone          String?
  sectorMetadata Json?    @map("sector_metadata")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  invoices           Invoice[]
  recurringContracts RecurringContract[]

  @@unique([tenantId, nif])
  @@map("clients")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  description    String?
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  vatRate        Decimal  @map("vat_rate") @db.Decimal(5, 2)
  unit           String   @default("ud")
  sectorMetadata Json?    @map("sector_metadata")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  invoiceLines InvoiceLine[]

  @@map("products")
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  series         String
  number         Int
  issuedAt       DateTime  @map("issued_at")
  dueAt          DateTime? @map("due_at")
  status         String    @default("draft")    // draft | sent | paid | overdue | cancelled | rectified
  type           String    @default("F1")       // F1 | R1 | R2 | R3 | R4 | R5
  rectifiedId    String?   @map("rectified_id") @db.Uuid
  notes          String?
  sectorMetadata Json?     @map("sector_metadata")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  client         Client          @relation(fields: [clientId], references: [id])
  lines          InvoiceLine[]
  records        InvoiceRecord[]
  rectifiedBy    Invoice?        @relation("Rectification", fields: [rectifiedId], references: [id])
  rectifications Invoice[]       @relation("Rectification")

  @@unique([tenantId, series, number])
  @@map("invoices")
}

// ─── InvoiceLine ──────────────────────────────────────────────────────────────

model InvoiceLine {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  productId   String? @map("product_id") @db.Uuid
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  vatRate     Decimal @map("vat_rate") @db.Decimal(5, 2)
  sortOrder   Int     @default(0) @map("sort_order")

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@map("invoice_lines")
}

// ─── InvoiceRecord ────────────────────────────────────────────────────────────
// Verifactu submission log — immutable after creation

model InvoiceRecord {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  invoiceId    String    @map("invoice_id") @db.Uuid
  type         String    @default("Alta") // Alta | Anulacion
  hash         String
  previousHash String?   @map("previous_hash")
  canonicalXml String    @map("canonical_xml") @db.Text
  sentAt       DateTime? @map("sent_at")
  aeatResponse Json?     @map("aeat_response")
  status       String    @default("pending") // pending | accepted | rejected | error
  createdAt    DateTime  @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_records")
}

// ─── RecurringContract ────────────────────────────────────────────────────────

model RecurringContract {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  name           String
  frequency      String   @default("monthly") // weekly | biweekly | monthly | quarterly | yearly
  nextBillingAt  DateTime @map("next_billing_at")
  amount         Decimal  @db.Decimal(12, 2)
  active         Boolean  @default(true)
  sectorMetadata Json?    @map("sector_metadata")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  @@map("recurring_contracts")
}

// ─── Invitation ───────────────────────────────────────────────────────────────

model Invitation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String
  role      UserRole @default(MEMBER)
  token     String   @unique @default(dbgenerated("gen_random_uuid()::text"))
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("invitations")
}
