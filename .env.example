# ===================================================
# NEXO BILLING — Environment Variables
# Copy this file to .env.local and fill values
# ===================================================

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                  # Secret - only server-side

# --- Database ---
# Pooler (port 6543) — used by Prisma at runtime (serverless-safe)
DATABASE_URL=postgresql://postgres.<project-ref>:password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct (port 5432) — used by prisma migrate dev/deploy only
DIRECT_URL=postgresql://postgres.<project-ref>:password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# --- Supabase Management API (dev tooling — never deploy) ---
SUPABASE_ACCESS_TOKEN=sbp_
SUPABASE_PROJECT_REF=

# --- Verifactu Provider ---
VERIFACTU_PROVIDER=verifacti                # verifacti | aeat-native | mock
VERIFACTI_API_KEY=
VERIFACTI_API_URL=https://api.verifacti.com
VERIFACTI_ENVIRONMENT=sandbox               # sandbox | production

# --- Fabricante SIF (para declaración responsable) ---
SIF_MANUFACTURER_NIF=
SIF_MANUFACTURER_NAME=Nexo Digital
SIF_PRODUCT_NAME=Nexo Billing
SIF_PRODUCT_VERSION=0.1.0
SIF_CERTIFICATE_PATH=./certs/sif-signing.p12
SIF_CERTIFICATE_PASSWORD=

# --- Stripe (payments for the SaaS itself) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- GoCardless (SEPA for spanish customers) ---
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_WEBHOOK_SECRET=
GOCARDLESS_ENVIRONMENT=sandbox

# --- Email ---
RESEND_API_KEY=
EMAIL_FROM=facturas@nexo-billing.app

# --- WhatsApp Business (bot de facturación) ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- OCR (gastos y tickets) ---
MINDEE_API_KEY=

# --- Google Maps (optimización rutas - vertical limpieza) ---
GOOGLE_MAPS_API_KEY=

# --- Observability ---
SENTRY_DSN=
POSTHOG_KEY=
