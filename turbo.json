{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "DATABASE_URL",
        "DIRECT_URL",
        "SUPABASE_ACCESS_TOKEN",
        "SUPABASE_PROJECT_REF",
        "HEALTH_CHECK_TOKEN",
        "NODE_ENV",
        "VERCEL_ENV",
        "RESEND_API_KEY",
        "EMAIL_FROM",
        "PUBLIC_INVOICE_TOKEN_SECRET",
        "NEXT_PUBLIC_APP_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "GOCARDLESS_ACCESS_TOKEN",
        "GOCARDLESS_WEBHOOK_SECRET",
        "GOCARDLESS_ENVIRONMENT",
        "TENANT_SECRET_ENCRYPTION_KEY",
        "VERIFACTU_PROVIDER",
        "VERIFACTU_API_KEY",
        "VERIFACTU_API_URL",
        "VERIFACTU_MOCK_MODE"
      ],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
